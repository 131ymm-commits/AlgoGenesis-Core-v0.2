    evolution = AlgoGenesis(
        pop_size=25,
        generations=100,
        env_name='CartPole-v1',
        revolution_prob=0.09,
        elite_fraction=0.25,
    )
    
    best_agent = evolution.run()
    
    # Save results
    evolution.save_statistics("results")
    evolution.plot_evolution("results")
    
    logger.info(f"\n🏆 FINAL RESULTS:")
    logger.info(f"   Best Agent Fitness: {best_agent.fitness:.1f}")
    logger.info(f"   Final γ_eff: {best_agent.gamma:.4f}")
    logger.info(f"   Total revolutions triggered: {len(evolution.revolution_events)}")
